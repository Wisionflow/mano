ANTHROPIC_API_KEY=your_key_here
# Model: claude-sonnet-4-5-20250929 ($3/$15) | claude-haiku-4-5-20251001 ($1/$5)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Telegram bot (create via @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Patient's Telegram user ID (diary auto-records from this user)
TELEGRAM_PATIENT_ID=
# Family members: id:name,id:name (full access, no auto-diary)
TELEGRAM_FAMILY=
# All allowed users (comma-separated IDs)
TELEGRAM_ALLOWED_USERS=
